# Configuración del entorno para Dunita Game

# URL del backend desplegado en Railway
# Para desarrollo local: http://localhost:8000
# Para producción: https://tu-proyecto.up.railway.app
REMOTE_API_URL=http://localhost:8000

# ID único del usuario para guardar/cargar partidas remotas
# Usa un ID único por usuario/jugador (ej: email, UUID, nickname)
REMOTE_USER_ID=tu_usuario_unico

# Timeout en segundos para llamadas al backend remoto
REMOTE_REQUEST_TIMEOUT=8.0

# Credenciales de Firebase (solo para desarrollo local)
# Copia el contenido completo del JSON de service account descargado de Firebase
# FIREBASE_CREDENTIALS_JSON={"type": "service_account", "project_id": "...", ...}
